# ICU Smart Monitoring — Backend configuration
# Copier ce fichier vers `.env` et ajuster.

ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=720
SEED_ADMIN_EMAIL=admin@icu.local
SEED_ADMIN_PASSWORD=admin

# --- Temps réel ---
TICK_INTERVAL_S=1.0
ECG_SAMPLES_PER_TICK=125

# --- Base de données (laisser vide pour tourner en mémoire, sans PostgreSQL) ---
# DATABASE_URL=postgresql+asyncpg://icu:icu@localhost:5432/icu

# --- Gemini (OPTIONNEL — résumés textuels uniquement, jamais temps réel) ---
GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
